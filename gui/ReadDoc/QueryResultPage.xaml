<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReadDoc.QueryResultPage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit" CanBeDismissedByTappingOutsideOfPopup="False">
    <VerticalStackLayout WidthRequest="500" HeightRequest="180">
        <Label Text="Query Result" HorizontalOptions="Center" FontAttributes="Bold" FontSize="14" Margin="0,10,0,0"/>
        <Border Stroke="Gray" StrokeShape="RoundRectangle 5,5,5,5" Padding="8" Margin="3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ScrollView Grid.Row="0" Grid.Column="0">
                    <Label x:Name="QueryResultText" VerticalOptions="Start" HorizontalOptions="Start" LineBreakMode="WordWrap" MaxLines="-1"/>
                </ScrollView>
            </Grid>
        </Border>
        <Button x:Name="cmdClose" Text="Close" HeightRequest="40" WidthRequest="100" VerticalOptions="End" HorizontalOptions="Center" Margin="0,5,0,0" Clicked="cmdClose_Clicked"/>
    </VerticalStackLayout>
</toolkit:Popup>